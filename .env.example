# ─── SHOPIFY STOREFRONT API ───────────────────────────
# Setup steps:
# 1. In Shopify admin → Apps → Develop apps → Create an app
# 2. Under "API credentials" tab → Storefront API access scopes
#    Enable: unauthenticated_read_product_listings, unauthenticated_read_product_inventory,
#            unauthenticated_write_checkouts, unauthenticated_read_checkouts,
#            unauthenticated_read_content (for collections/brands)
# 3. Copy the "Storefront API access token" (public token, safe to expose client-side)
#
# Products: manage in Shopify admin → Products
# Brands:   manage in Shopify admin → Products → Collections (one collection per brand)
#
# Metafields (Products): custom.designer, custom.year, custom.material,
#                        custom.dimensions, custom.lead_time, custom.subcategory
# Metafields (Collections/brands): custom.brand_key, custom.country, custom.city,
#                                   custom.founded, custom.website, custom.tagline,
#                                   custom.color, custom.featured
# Add metafield definitions at: Shopify admin → Settings → Custom data
#
# Tags used on products:
#   "featured"         — appears in featured sections
#   "badge:nouveau"    — shows "Nouveau" badge
#   "badge:limite"     — shows "Limité" badge
#   "badge:bestseller" — shows "Bestseller" badge
#   "sub:fauteuils"    — subcategory (alternative to metafield)
#
# Webhooks (optional cache invalidation):
#   Shopify admin → Settings → Notifications → Webhooks
#   → Products/update  → POST {BASE_URL}/api/revalidate
#   → Collections/update → POST {BASE_URL}/api/revalidate

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
SHOPIFY_API_VERSION=2024-10

# Checkout domain (headless setup). The front-end owns www.mikadodeco.be (Vercel),
# so Shopify checkout must run on a Shopify-pointed subdomain. Set this to that
# subdomain (e.g. shop.mikadodeco.be) once it is a CNAME to shops.myshopify.com AND
# set as the store's primary domain in Shopify -> Settings -> Domains. Leave blank
# to use whatever host Shopify returns.
SHOPIFY_CHECKOUT_DOMAIN=

# ─── SERVER ───────────────────────────────────────────
PORT=4000
BASE_URL=http://localhost:4000
