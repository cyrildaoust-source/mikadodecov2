# ─── SANITY CMS ──────────────────────────────────────────
# Setup steps:
# 1. cd studio && npm install
# 2. npx sanity login
# 3. npx sanity init   → creates project, gives you a Project ID
# 4. npx sanity deploy → deploys the studio to sanity.io
# 5. node scripts/import-to-sanity.js  → imports products + brands
# Generate API token at: sanity.io/manage → project → API → Tokens
SANITY_PROJECT_ID=YOUR_PROJECT_ID
SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── ODOO (optional — sync products from Odoo to Sanity) ─
# POST /api/sync-odoo once configured to pull products into Sanity.
# Requires Odoo 16+ with REST API enabled.
# Generate API key: Settings → Technical → API Keys
ODOO_URL=https://yourcompany.odoo.com
ODOO_API_KEY=

# ─── STRIPE ──────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — from `stripe listen --forward-to localhost:4000/webhook`
# or from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── SERVER ──────────────────────────────────────────────
PORT=4000
BASE_URL=http://localhost:4000

# ─── EMAIL (optional — for order notifications) ──────────
# Uses nodemailer. Any SMTP provider works (Gmail, Resend, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SHOP_EMAIL=bonjour@atelierforme.be
